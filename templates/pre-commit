#!/usr/bin/env sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

canon_bin="${CANON_BIN:-}"
if [ -z "$canon_bin" ]; then
  if [ -x "$repo_root/target/debug/canon" ] &&
    [ -f "$repo_root/.codex-plugin/plugin.json" ] &&
    grep -q '"name"[[:space:]]*:[[:space:]]*"canon"' "$repo_root/.codex-plugin/plugin.json"; then
    canon_bin="$repo_root/target/debug/canon"
  elif command -v canon >/dev/null 2>&1; then
    canon_bin="$(command -v canon)"
  fi
fi

if [ -z "$canon_bin" ]; then
  echo "canon pre-commit: canon is not on PATH" >&2
  echo "Install canon first: https://github.com/progbeat/canon#quick-start" >&2
  exit 1
fi

if [ ! -x "$canon_bin" ]; then
  echo "canon pre-commit: canon binary is not executable: $canon_bin" >&2
  exit 1
fi

if ! "$canon_bin" help 2>/dev/null | grep -q "canon gate"; then
  echo "canon pre-commit: $canon_bin does not support 'canon gate'" >&2
  echo "Update canon first: https://github.com/progbeat/canon#quick-start" >&2
  exit 1
fi

echo "canon pre-commit: running canon gate"
# Hook command: `canon gate`.
# This pre-commit hook runs `canon gate`, not `canon check`.
# `canon gate` is intentionally cache-only: missing cached answers and cached
# failing answers make the hook exit here without invoking `canon check`.
# Do not add a separate `.canon/**` preflight here; `canon gate` owns the
# `.canon/**`-only unchanged-visible-content exception.
if ! "$canon_bin" gate; then
  echo "canon pre-commit: canon gate failed." >&2
  exit 1
fi
